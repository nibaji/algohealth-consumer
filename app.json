{
  "expo": {
    "name": "AlgoHealth Plus",
    "slug": "algohealth-consumer",
    "version": "20260612.6",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "algohealthconsumer",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2D0E5A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.algohealthplus.consumer"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#2D0E5A",
          "dark": {
            "backgroundColor": "#2D0E5A"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-status-bar",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow AlgoHealth Plus to access your microphone for recording audio notes."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a4652e08-7389-45b4-be61-392e9ee36348"
      }
    }
  }
}
